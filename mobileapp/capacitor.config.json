{
  "appId": "com.ckdguardian.mobileapp",
  "appName": "CKD Guardian",
  "webDir": "www",
  "server": {
    "url": "https://ckd-guardian.vercel.app",
    "cleartext": false,
    "allowNavigation": [
      "ckd-guardian.vercel.app",
      "ckd-guardian-backend.onrender.com"
    ]
  },
  "ios": {
    "contentInset": "automatic"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000
    },
    "StatusBar": {
      "overlaysWebView": false,
      "style": "LIGHT",
      "backgroundColor": "#f4f6fa"
    }
  }
}