{
  "appId": "com.ckdguardian.mobileapp",
  "appName": "CKD Guardian",
  "webDir": "www",
  "server": {
    "url": "https://ckdguardianofficial.vercel.app",
    "cleartext": false,
    "androidScheme": "https",
    "allowNavigation": [
      "accounts.google.com",
      "*.google.com"
    ]
  },
  "android": {
    "overrideUserAgent": "Mozilla/5.0 (Linux; Android 13; Pixel 7 Pro) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/114.0.0.0 Mobile Safari/537.36"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "517326262037-uojhm7s67ti7o67cea0a6l8da3tvk2kt.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  }
}